// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/jekyll
{
	"name": "Fanfinity Website",
	// Jekyll 4.3 + Tailwind site: needs Ruby (bundler) and Node — the official Jekyll
	// devcontainer image ships both (Ruby 3.x + Node LTS).
	"image": "mcr.microsoft.com/devcontainers/jekyll:2-bookworm",
	"features": {
		// dot-config feature dropped: its installer exits 127 on the jekyll base image.
		"ghcr.io/devcontainer-community/devcontainer-features/github.com-cli:1": {},
		// The jekyll image ships Ruby but no Node; Tailwind build needs npm (Node 20 LTS).
		"ghcr.io/devcontainers/features/node:1": {
			"version": "20"
		}
	},

	// Mount the host folder as the workspace inside the container.
	"workspaceMount": "source=/home/abumusa/Desktop/fanfinity/marketing/website,target=/workspaces/website,type=bind,consistency=cached",
	"workspaceFolder": "/workspaces/website",

	// Jekyll dev server (npm run dev → Tailwind watch + Jekyll live-reload).
	// appPort publishes 4000 (site) + 35729 (livereload websocket) on the host at
	// container start, so http://localhost:4000 works from any browser — no VS Code
	// forwarding needed. jekyll serve must bind 0.0.0.0 (see package.json dev script).
	"appPort": [4000, 35729],
	"forwardPorts": [4000],

	// Install site dependencies after the container is created.
	"postCreateCommand": "bundle install && npm install"

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
