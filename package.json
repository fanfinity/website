{
  "name": "website",
  "private": true,
  "scripts": {
    "css:build": "npx tailwindcss -i ./src/main.css -o ./assets/css/main.css --minify",
    "css:watch": "npx tailwindcss -i ./src/main.css -o ./assets/css/main.css --watch",
    "build": "npm run css:build && bundle exec jekyll build",
    "dev": "npm run css:watch & bundle exec jekyll serve --livereload"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "tailwindcss": "^3.4.0"
  }
}
